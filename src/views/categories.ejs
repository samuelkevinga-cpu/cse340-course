<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>

        <% if (!categories || categories.length === 0) { %>
            <p>No categories are available right now.</p>
        <% } else { %>
            <ul>
                <% categories.forEach((category) => { %>
                    <li>
                        <a href="/category/<%= category.category_id %>"><%= category.name %></a>
                    </li>
                <% }) %>
            </ul>
        <% } %>
    </main>

    <%- include('partials/footer') %>
