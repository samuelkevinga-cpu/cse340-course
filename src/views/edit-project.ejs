<%- include('partials/header') %>
<main>
    <% const toDateInputValue = (value) => { %>
        <% if (!value) return ''; %>
        <% if (typeof value === 'string' && /^\d{4}-\d{2}-\d{2}/.test(value)) { %>
            <% return value.slice(0, 10); %>
        <% } %>
        <% const date = value instanceof Date ? value : new Date(value); %>
        <% if (Number.isNaN(date.getTime())) return ''; %>
        <% const year = date.getUTCFullYear(); %>
        <% const month = String(date.getUTCMonth() + 1).padStart(2, '0'); %>
        <% const day = String(date.getUTCDate()).padStart(2, '0'); %>
        <% return `${year}-${month}-${day}`; %>
    <% } %>

    <h1><%= title %></h1>

    <form action="/edit-project/<%= project.project_id %>" method="POST">
        <div class="form-group">
            <label for="title">Project Title</label>
            <input
                type="text"
                id="title"
                name="title"
                maxlength="150"
                placeholder="e.g. Neighborhood Cleanup"
                value="<%= project.title %>"
                required
            />
        </div>

        <div class="form-group">
            <label for="description">Description</label>
            <textarea
                id="description"
                name="description"
                maxlength="500"
                placeholder="Describe what volunteers will do at this project"
                required
            ><%= project.description %></textarea>
        </div>

        <div class="form-group">
            <label for="location">Location</label>
            <input
                type="text"
                id="location"
                name="location"
                maxlength="255"
                placeholder="e.g. Maple Street Park"
                value="<%= project.location %>"
                required
            />
        </div>

        <div class="form-group">
            <label for="date">Date</label>
            <input
                type="date"
                id="date"
                name="date"
                value="<%= toDateInputValue(project.date) %>"
                required
            />
        </div>

        <div class="form-group">
            <label for="organizationId">Organization</label>
            <select
                id="organizationId"
                name="organizationId"
                required
            >
                <option value="">Select an organization</option>
                <% organizations.forEach(org => { %>
                    <option
                        value="<%= org.organization_id %>"
                        <%= Number(org.organization_id) === Number(project.organization_id) ? 'selected' : '' %>
                    >
                        <%= org.name %>
                    </option>
                <% }); %>
            </select>
        </div>

        <button type="submit">Update Project</button>
    </form>
</main>
<%- include('partials/footer') %>
