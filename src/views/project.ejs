<%- include('partials/header') %>

<main>
    <% const formatProjectDate = (value) => { %>
        <% if (!value) return 'TBD'; %>
        <% if (typeof value === 'string' && /^\d{4}-\d{2}-\d{2}$/.test(value)) { %>
            <% const [year, month, day] = value.split('-').map(Number); %>
            <% const date = new Date(Date.UTC(year, month - 1, day)); %>
            <% return new Intl.DateTimeFormat('en-US', {
                month: 'long',
                day: 'numeric',
                year: 'numeric',
                timeZone: 'UTC'
            }).format(date); %>
        <% } %>
        <% const date = value instanceof Date ? value : new Date(value); %>
        <% if (Number.isNaN(date.getTime())) return 'TBD'; %>
        <% return new Intl.DateTimeFormat('en-US', {
            month: 'long',
            day: 'numeric',
            year: 'numeric'
        }).format(date); %>
    <% } %>

    <h1><%= project.title %></h1>
    <p><%= project.description %></p>
    <p><strong>Date:</strong> <%= formatProjectDate(project.date) %></p>
    <p><strong>Location:</strong> <%= project.location %></p>
    <p>
        <strong>Partner Organization:</strong>
        <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>
    </p>

    <% if (categories && categories.length > 0) { %>
        <p><strong>Categories:</strong></p>
        <ul>
            <% categories.forEach((category) => { %>
                <li>
                    <a href="/category/<%= category.category_id %>"><%= category.name %></a>
                </li>
            <% }) %>
        </ul>
    <% } %>
</main>

<%- include('partials/footer') %>
