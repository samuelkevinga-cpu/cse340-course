<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>
        <% const formatProjectDate = (value) => { %>
            <% if (!value) return 'TBD'; %>
            <% if (typeof value === 'string' && /^\d{4}-\d{2}-\d{2}$/.test(value)) { %>
                <% const [y, m, d] = value.split('-').map(Number); %>
                <% const dt = new Date(Date.UTC(y, m - 1, d)); %>
                <% return new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' }).format(dt); %>
            <% } %>
            <% const dt = value instanceof Date ? value : new Date(value); %>
            <% if (Number.isNaN(dt.getTime())) return 'TBD'; %>
            <% return new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).format(dt); %>
        <% } %>

        <% if (!projects || projects.length === 0) { %>
            <p>No projects are available right now.</p>
        <% } else { %>
            <ul>
                <% projects.forEach((project) => { %>
                    <li>
                        <strong><%= formatProjectDate(project.date) %>:
                            <a href="/project/<%= project.project_id %>"><%= project.title %></a>
                        </strong>
                        (<em><a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a></em>)
                        <p><%= project.description %></p>
                        <p><strong>Location:</strong> <%= project.location %></p>
                    </li>
                <% }) %>
            </ul>
        <% } %>
    </main>
    <%- include('partials/footer') %>